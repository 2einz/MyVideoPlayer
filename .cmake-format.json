{
  "parse": {
    "additional_commands": {
      "qt_add_qml_module": {
        "pargs": 1,
        "kwargs": {
          "URI": 1,
          "VERSION": 1,
          "RESOURCE_PREFIX": 1,
          "QML_FILES": "+",
          "RESOURCES": "+"
        }
      },
      "find_package": {
        "pargs": 1,
        "flags": ["REQUIRED", "QUIET", "MODULE", "CONFIG"],
        "kwargs": {
          "COMPONENTS": "+",
          "OPTIONAL_COMPONENTS": "+"
        }
      },
      "qt_add_executable": {
        "pargs": 1,
        "flags": ["WIN32", "MACOSX_BUNDLE"]
      }
    }
  },
  "format": {
    "line_width": 100,
    "tab_size": 4,
    "command_case": "lower",
    "dangle_parens": true,
    "max_pargs_hwrap": 2,
    "separate_ctrl_name_with_space": false,
    "separate_fn_name_with_space": false,
    "always_wrap": [
      "target_link_libraries",
      "target_sources",
      "target_include_directories",
      "find_package"
    ]
  },
  "markup": {
    "enable_markup": false
  }
}